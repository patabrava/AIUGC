# FLOW-FORGE Environment Variables
# Copy to .env and fill in your values

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ACCESS_TOKEN=sbp_...

# LLM Providers
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
GEMINI_PROVIDER=vertex
GEMINI_DEEP_RESEARCH_PROVIDER=vertex_grounded
GEMINI_API_FALLBACK_ENABLED=false
GEMINI_API_KEY=
GEMINI_TOPIC_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
GEMINI_DEEP_RESEARCH_AGENT=deep-research-preview-04-2026
GEMINI_TOPIC_TIMEOUT_SECONDS=600
GEMINI_TOPIC_POLL_SECONDS=5
VERTEX_GEMINI_MODEL=gemini-2.5-flash
VERTEX_GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
VERTEX_GROUNDED_RESEARCH_MODEL=gemini-2.5-pro
VERTEX_GROUNDED_RESEARCH_LOCATION=global
TOPIC_AUDIT_INTERVAL_SECONDS=60
TOPIC_RESEARCH_INTERVAL_SECONDS=86400
TOPIC_WORKER_POLL_INTERVAL_SECONDS=60
ANTHROPIC_API_KEY=sk-ant-...

# Video Providers
GOOGLE_AI_API_KEY=your-google-ai-api-key
GOOGLE_AI_PROJECT_ID=your-google-project-id
VERTEX_AI_ENABLED=true
VERTEX_AI_PROJECT_ID=project-89aac146-ec35-4755-b83
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_OUTPUT_GCS_URI=gs://your-vertex-output-bucket/
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_APPLICATION_CREDENTIALS_JSON=
# SORA_API_KEY=your-sora-key  # Future implementation

# Video Storage (Cloudflare R2)
CLOUDFLARE_R2_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-access-key-id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
CLOUDFLARE_R2_BUCKET_NAME=your-r2-bucket-name
CLOUDFLARE_R2_PUBLIC_BASE_URL=https://cdn.example.com
CLOUDFLARE_R2_REGION=auto
CLOUDFLARE_R2_ENDPOINT_URL=
CLOUDFLARE_R2_VIDEO_PREFIX=flow-forge/videos
USE_URL_BASED_UPLOAD=true

# Social Media
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_REDIRECT_URI=http://localhost:8000/publish/meta/callback
TIKTOK_CLIENT_KEY=your-tiktok-key
TIKTOK_CLIENT_SECRET=your-tiktok-secret
TIKTOK_REDIRECT_URI=http://localhost:8000/publish/tiktok/callback
TIKTOK_ENVIRONMENT=sandbox
TIKTOK_SANDBOX_ACCOUNT=@your-sandbox-handle
INSTAGRAM_ACCESS_TOKEN=your-instagram-token
APP_URL=http://localhost:8000
PRIVACY_POLICY_URL=https://yourdomain.com/privacy
TERMS_URL=https://yourdomain.com/terms
TOKEN_ENCRYPTION_KEY=change-me-long-random-secret

# Auth (email OTP login)
ALLOWED_EMAIL_DOMAIN=lippelift.de
ALLOWED_EMAILS=caposk817@gmail.com
REVIEWER_LOGIN_EMAIL=tiktok-review@lippelift.xyz
REVIEWER_LOGIN_TOKEN=change-me-review-token
SESSION_COOKIE_NAME=ff_session
SESSION_MAX_AGE=2592000
AUTH_OTP_CODE_LENGTH=8

# Cron Security
CRON_SECRET=your-random-secret-string

# Application
DEBUG=0
LOG_LEVEL=INFO
ENVIRONMENT=development
APP_HOST=localhost
APP_PORT=8000
WEBFLOW_API_TOKEN=
WEBFLOW_SITE_ID=
WEBFLOW_COLLECTION_ID=
CLOUDFLARE_R2_IMAGE_PREFIX=flow-forge/images
